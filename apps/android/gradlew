#!/bin/sh
# Gradle start up script for POSIX generated by Gradle.
# Requires gradle/wrapper/gradle-wrapper.jar (generated by Android Studio sync
# or by running `gradle wrapper --gradle-version 8.13`).
set -e
APP_HOME=$( cd "${0%/*}" && pwd -P )
APP_BASE_NAME=${0##*/}
DEFAULT_JVM_OPTS='-Xmx64m -Xms64m'

if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
    if [ ! -x "$JAVACMD" ] ; then
        echo "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME" >&2
        exit 1
    fi
else
    JAVACMD=java
    command -v java >/dev/null 2>&1 || {
        echo "ERROR: JAVA_HOME is not set and no 'java' command in PATH." >&2
        exit 1
    }
fi

CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
if [ ! -f "$CLASSPATH" ] ; then
    echo "ERROR: gradle-wrapper.jar not found. Open the project in Android Studio" >&2
    echo "       (it regenerates the wrapper), or run: gradle wrapper --gradle-version 8.13" >&2
    exit 1
fi

exec "$JAVACMD" $DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS \
    -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
