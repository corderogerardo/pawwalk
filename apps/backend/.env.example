# Copy to .env and fill in to enable the real LLM-powered booking assistant.
# Without these, the assistant still works using a built-in heuristic parser.

# Database connection (SQLite by default; same code works against Postgres
# by changing only this URL).
PAWWALK_DATABASE_URL=sqlite:///./pawwalk.db

# Required. Secret used to sign JWTs — no default, the app refuses to start
# without it. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
PAWWALK_JWT_SECRET=

# Optional — defaults shown.
# PAWWALK_JWT_ALG=HS256
# PAWWALK_JWT_EXPIRE_MINUTES=10080

# Which model Pydantic AI should use, e.g. openai:gpt-4o-mini, anthropic:claude-3-5-haiku-latest
PAWWALK_LLM_MODEL=

# Provider key the model needs (Pydantic AI reads these from the environment).
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional — Stripe test-mode keys. Without these, /payments/intent keeps
# returning the offline stub client_secret instead of a real PaymentIntent.
PAWWALK_STRIPE_SECRET_KEY=
PAWWALK_STRIPE_WEBHOOK_SECRET=
