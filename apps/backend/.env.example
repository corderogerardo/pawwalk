# Copy to .env and fill in to enable the real LLM-powered booking assistant.
# Without these, the assistant still works using a built-in heuristic parser.

# Which model Pydantic AI should use, e.g. openai:gpt-4o-mini, anthropic:claude-3-5-haiku-latest
PAWWALK_LLM_MODEL=

# Provider key the model needs (Pydantic AI reads these from the environment).
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
